# ==================================================================
#  Веб-приложение (web.py) настраивается ЧЕРЕЗ UI (⚙ Настройки) —
#  токен бота и креды Nextcloud хранятся в data/config.json на сервере.
#  Этот .env нужен только для CLI/бота (cli.py, bot.py) и хостинга.
# ==================================================================

# ---- Хостинг веб-приложения ----
# Каталог для config.json и собранных файлов.
DATA_DIR=data
# Кому разрешено встраивать UI в iframe (Nextcloud External Sites).
# Несколько источников — через пробел. Напр.: 'self' https://cloud.example.com
FRAME_ANCESTORS='self'

# ---- Только для CLI (cli.py) и бота (bot.py) ----
DISCORD_TOKEN=
GUILD_ID=
NEXTCLOUD_URL=https://cloud.example.com
NEXTCLOUD_USER=твой_логин
NEXTCLOUD_APP_PASSWORD=
NEXTCLOUD_DIR=discord-scrapes
AUTHOR_IDS=
CHARACTER_NAMES=
TIMEZONE=
TIME_FORMAT=%Y-%m-%d %H:%M:%S
