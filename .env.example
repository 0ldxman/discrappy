# ==================================================================
#  Веб-приложение (web.py) настраивается ЧЕРЕЗ UI (⚙ Настройки) —
#  токен бота и креды Nextcloud хранятся в data/config.json на сервере.
#  Этот .env нужен только для CLI/бота (cli.py, bot.py) и хостинга.
# ==================================================================

# ---- Хостинг веб-приложения ----
# Каталог для config.json и собранных файлов.
DATA_DIR=data
# Кому разрешено встраивать UI в iframe (Nextcloud External Sites).
# Несколько источников — через пробел. Напр.: 'self' https://cloud.example.com
FRAME_ANCESTORS='self'

# ---- Только для CLI (cli.py) и бота (bot.py) ----
DISCORD_TOKEN=
GUILD_ID=
NEXTCLOUD_URL=https://cloud.example.com
NEXTCLOUD_USER=твой_логин
NEXTCLOUD_APP_PASSWORD=
NEXTCLOUD_DIR=discord-scrapes
AUTHOR_IDS=
# Маски (* и ?), регистронезависимо, через запятую или перевод строки.
CHARACTER_NAMES=          # белый список имён (пусто = любой)
NAME_BLACKLIST=           # чёрный список имён, напр.: Система,GM*
# --- служебный текст ---
TEXT_CONTAINS=            # подстроки (основной режим), напр.: вошёл в игру,ход перешёл
TEXT_BLACKLIST=           # маски по тексту (продвинутое), напр.: *вошёл*
TEXT_FUZZY=               # примеры служебных сообщений для нечёткого сравнения
FUZZY_THRESHOLD=0.82      # порог похожести 0.1..1.0
# --- формат ---
TIMEZONE=
TIME_FORMAT=%Y-%m-%d %H:%M:%S
OUTPUT_FORMAT=obsidian     # obsidian | txt
# --- режим сбора ---
MODE=both                  # both | embeds | text
# --- сбор из текста ---
TEXT_NAME_PATTERNS=({name}) {text}
TEXT_FALLBACK_NICK=        # true/пусто
TEXT_IGNORE_BOTS=true
TEXT_COMMAND_PREFIXES=! . /
TEXT_OOC_PREFIXES=(( // [
